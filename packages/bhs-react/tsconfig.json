{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "noImplicitOverride": true,
    "noUncheckedSideEffectImports": false,
    "strict": true,
    "paths": {
      "@/*": [
        "./*",
      ],
    },
    "types": [
      "jest",
    ],
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
  ],
}
